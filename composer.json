{
    "name": "dgarbs51/job-execution-recorder",
    "description": "Laravel listener package for recording queue job execution metrics.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "DGarbs51\\JobExecutionRecorder\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\": "tests/Fixtures/App/",
            "DGarbs51\\JobExecutionRecorder\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "DGarbs51\\JobExecutionRecorder\\JobExecutionRecorderServiceProvider"
            ]
        }
    },
    "require-dev": {
        "orchestra/testbench": "^11.1",
        "phpunit/phpunit": "^13.1"
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
